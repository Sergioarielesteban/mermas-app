# Supabase (app)
# URL del proyecto (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
# Clave anónima (cliente); nunca la service role en el navegador
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_URL=

# Sitio público (OG, enlaces absolutos)
NEXT_PUBLIC_SITE_URL=https://chef-one.com

# Landing: si el formulario falla, mensaje “escríbenos a…” (visible solo en error)
NEXT_PUBLIC_CONTACT_EMAIL=sergioarielesteban@hotmail.com

# Landing: botones “Llamar” y WhatsApp. Opcional: si lo omites, se usa el número por defecto en código (+34 668 541 933).
NEXT_PUBLIC_CONTACT_PHONE=34668541933

# Landing: aviso por correo al guardar consulta (Resend — https://resend.com)
# 1) Crea cuenta, API Keys → copia la key
# 2) LEADS_NOTIFY_EMAIL = donde quieres recibir (ej. tu Hotmail)
# 3) RESEND_FROM: con dominio verificado en Resend (recomendado: notificaciones@chef-one.com)
#    Sin dominio, Resend solo deja probar con onboarding@resend.dev hacia el email con el que te registraste
RESEND_API_KEY=
LEADS_NOTIFY_EMAIL=sergioarielesteban@hotmail.com
RESEND_FROM_EMAIL=Chef-One <onboarding@resend.dev>

# Opcional: restricción extra de emails en login legacy (sin Supabase). Lista separada por comas. Vacío = sin filtro por email en cliente.
# NEXT_PUBLIC_LOGIN_EMAIL_ALLOWLIST=

# ── OCR albaranes (solo Google Cloud) ───────────────────────────────────────
# Document AI (texto) en POST /api/pedidos/ocr; Document AI + Gemini en POST /api/ocr/process.
# Sin estas variables el OCR de albaranes no funciona (no hay proveedor alternativo).
#
# 1) Crear proyecto en Google Cloud y habilitar Document AI API.
# 2) Crear un procesador "Form Parser" o "Invoice Parser" (region: eu o us).
# 3) Crear service account con rol "Document AI API User" y descargar JSON.
# 4) Crear API key de Gemini en https://aistudio.google.com/app/apikey
#
# El JSON de la service account se pasa entero como string (Vercel acepta
# multi-línea en envs; en local pega el contenido escapando saltos de línea o
# usando "\n" dentro de "private_key").
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_DOCUMENT_AI_LOCATION=eu
GOOGLE_DOCUMENT_AI_PROCESSOR_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=
GEMINI_API_KEY=
# Modelo Gemini (opcional). Default: gemini-2.0-flash-001
# GEMINI_MODEL=gemini-2.0-flash-001
